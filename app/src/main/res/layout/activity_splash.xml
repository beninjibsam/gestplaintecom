<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    android:fitsSystemWindows="true">

    <!-- =================== Bloc centre vertical+horizontal =================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp">

        <!-- Icône officielle de l'app avec glow doux -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/logo_glow"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center"
                android:background="@drawable/logo_glow_bg"
                android:alpha="0.55" />

            <ImageView
                android:id="@+id/logo_block"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:src="@drawable/app_icon"
                android:contentDescription="@string/app_name" />
        </FrameLayout>

        <!-- Titre application -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/splash_title"
            android:textColor="@color/coris_blue"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:alpha="0" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/splash_subtitle"
            android:textColor="@color/coris_blue_light"
            android:textSize="20sp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:alpha="0" />

        <View
            android:id="@+id/divider"
            android:layout_width="56dp"
            android:layout_height="3dp"
            android:layout_marginTop="16dp"
            android:background="@color/coris_red"
            android:alpha="0" />

        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/splash_tagline"
            android:textColor="@color/text_muted_on_light"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:alpha="0" />

        <!-- ============ Animation : 3 grands dots centrés ============ -->

        <LinearLayout
            android:id="@+id/dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:alpha="0">

            <View
                android:id="@+id/dot1"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/loading_dot" />
            <View
                android:id="@+id/dot2"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/loading_dot" />
            <View
                android:id="@+id/dot3"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/loading_dot" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bandeau marque tout en bas -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:text="© Coris Assurances Burkina Faso · v1.0"
        android:textColor="@color/coris_blue"
        android:textSize="11sp"
        android:alpha="0.6" />

</FrameLayout>
