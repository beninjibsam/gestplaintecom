<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background">

    <!-- ============ Logo Coris ============ -->

    <!-- Glow doux derrière le carré -->
    <View
        android:id="@+id/logo_glow"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/logo_glow_bg"
        android:alpha="0.7"
        app:layout_constraintTop_toTopOf="@id/logo_block"
        app:layout_constraintBottom_toBottomOf="@id/logo_block"
        app:layout_constraintStart_toStartOf="@id/logo_block"
        app:layout_constraintEnd_toEndOf="@id/logo_block" />

    <!-- Bloc logo + texte CORIS / ASSURANCES / BURKINA FASO -->
    <LinearLayout
        android:id="@+id/logo_block"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="40dp">

        <!-- Carré Coris (C/S rouge sur fond bleu) -->
        <ImageView
            android:id="@+id/logo_mark"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/coris_logo_mark"
            android:contentDescription="@string/app_name" />

        <!-- Bloc texte CORIS ASSURANCES BURKINA FASO -->
        <LinearLayout
            android:id="@+id/logo_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_coris"
                android:textColor="@color/coris_blue"
                android:textSize="38sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.02"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_assurances"
                android:textColor="@color/coris_blue"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.04"
                android:includeFontPadding="false"
                android:layout_marginTop="-4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_country"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.18"
                android:background="@drawable/burkina_strip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ============ Titre application ============ -->

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_title"
        android:textColor="@color/coris_blue"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:fontFamily="sans-serif-medium"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/logo_block"
        app:layout_constraintBottom_toTopOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_subtitle"
        android:textColor="@color/coris_blue_light"
        android:textSize="22sp"
        android:fontFamily="sans-serif-light"
        android:alpha="0"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toTopOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="64dp"
        android:layout_height="3dp"
        android:layout_marginTop="20dp"
        android:background="@color/coris_red"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_tagline"
        android:textColor="@color/text_muted_on_light"
        android:textSize="13sp"
        android:letterSpacing="0.15"
        android:layout_marginTop="16dp"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ============ Loader (dots rouges) ============ -->

    <LinearLayout
        android:id="@+id/dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="80dp"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dot1"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginHorizontal="6dp"
            android:background="@drawable/loading_dot" />
        <View
            android:id="@+id/dot2"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginHorizontal="6dp"
            android:background="@drawable/loading_dot" />
        <View
            android:id="@+id/dot3"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginHorizontal="6dp"
            android:background="@drawable/loading_dot" />
    </LinearLayout>

    <!-- Bandeau marque en bas -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="© Coris Assurances · v1.0"
        android:textColor="@color/text_muted_on_light"
        android:textSize="11sp"
        android:alpha="0.7"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
