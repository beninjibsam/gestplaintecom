<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    android:fitsSystemWindows="true">

    <!-- ================================================================== -->
    <!--  Tout est centré verticalement dans une chaîne packed               -->
    <!-- ================================================================== -->

    <!-- Glow doux derrière le logo -->
    <View
        android:id="@+id/logo_glow"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/logo_glow_bg"
        android:alpha="0.6"
        app:layout_constraintTop_toTopOf="@id/logo_block"
        app:layout_constraintBottom_toBottomOf="@id/logo_block"
        app:layout_constraintStart_toStartOf="@id/logo_block"
        app:layout_constraintEnd_toEndOf="@id/logo_block" />

    <!-- Logo Coris officiel (PNG, non modifié) -->
    <ImageView
        android:id="@+id/logo_block"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:src="@drawable/coris_logo"
        android:contentDescription="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="40dp" />

    <!-- Titre application -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_title"
        android:textColor="@color/coris_blue"
        android:textSize="26sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/logo_block"
        app:layout_constraintBottom_toTopOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_subtitle"
        android:textColor="@color/coris_blue_light"
        android:textSize="20sp"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:alpha="0"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toTopOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="56dp"
        android:layout_height="3dp"
        android:layout_marginTop="18dp"
        android:background="@color/coris_red"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_tagline"
        android:textColor="@color/text_muted_on_light"
        android:textSize="13sp"
        android:letterSpacing="0.15"
        android:layout_marginTop="14dp"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toTopOf="@id/dots"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ================================================================== -->
    <!--  ANIMATION centrale bien visible : 3 grands dots rouges rebondissants -->
    <!-- ================================================================== -->

    <LinearLayout
        android:id="@+id/dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="36dp"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/tagline"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/dot1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/loading_dot" />
        <View
            android:id="@+id/dot2"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/loading_dot" />
        <View
            android:id="@+id/dot3"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/loading_dot" />
    </LinearLayout>

    <!-- ================================================================== -->
    <!--  Bandeau marque en bas                                              -->
    <!-- ================================================================== -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="© Coris Assurances Burkina Faso · v1.0"
        android:textColor="@color/coris_blue"
        android:textSize="11sp"
        android:alpha="0.6"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
